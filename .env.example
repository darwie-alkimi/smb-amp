# Anthropic API Key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Beeswax credentials (leave blank to use mock mode)
BEESWAX_API_URL=https://your-account.api.beeswax.com
BEESWAX_USERNAME=
BEESWAX_PASSWORD=

# Stripe — use test mode keys (sk_test_...) for development
STRIPE_SECRET_KEY=

# Google Gemini — for AI creative image generation (get key at aistudio.google.com)
# Note: image generation requires billing to be enabled on the project
GEMINI_API_KEY=

# Hugging Face — for AI creative image generation (free tier, no billing required)
# Get token at huggingface.co/settings/tokens
HF_API_TOKEN=

# AdVision — publisher preview service
ADVISION_API_URL=https://advision-production.up.railway.app
